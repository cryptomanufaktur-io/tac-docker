COMPOSE_FILE=tac.yml
MONIKER=tac-docker
NETWORK=tacchain_239-1

TACCHAIND_TAG=v1.6.0
FRESH_INIT_WITH_DATA=false

EXTRA_FLAGS=

# Persistent peers from Tac network documentation
# Source: https://github.com/TacBuild/tacchain/blob/main/NETWORKS.md
PERSISTENT_PEERS=d0a80c43a10a6b60475864728db6d9ba4ead42d2@107.6.113.60:58960,10550a03e4f7fa487c78fbd07e0770e2b0f085c7@64.46.115.78:58960,0efae9d157f0ef60ad7d25507d6939799f832e34@173.244.202.99:58960,78079166d06e345dbf4a5c932ee3c69a04148e92@107.6.91.38:58960

# Use latest from http://snapshot.tac.ankr.com/
# Full node: http://snapshot.tac.ankr.com/tac-mainnet-full-latest.tar.lz4
# Archive node: http://snapshot.tac.ankr.com/tac-mainnet-archive-latest.tar.lz4
SNAPSHOT=

CL_GRPC_PORT=9090
CL_P2P_PORT=58960
CL_RPC_PORT=26657
REST_API_PORT=1317
RPC_PORT=45138
WS_PORT=45139

# Secure web proxy - advanced use, please see instructions
DOMAIN=example.com
RPC_HOST=tac
RPC_LB=tac-lb
WS_HOST=tacws
WS_LB=tacws-lb

# info, warn, error, trace
LOG_LEVEL=info

# External Docker network if using ext-network.yml
DOCKER_EXT_NETWORK=traefik_default

# You can pin the version of Tac Docker here
SCRIPT_TAG=

# Used by tacd update - please do not adjust
ENV_VERSION=1
